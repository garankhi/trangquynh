* text=auto eol=lf

# Source and config files
*.cs text diff=csharp
*.shader text
*.shadergraph text
*.hlsl text
*.cginc text
*.compute text
*.asmdef text
*.asmref text
*.json text
*.md text
*.txt text
*.xml text
*.yml text
*.yaml text
*.inputactions text

# Unity serialized text assets
*.meta text
*.unity text
*.prefab text
*.asset text
*.mat text
*.anim text
*.controller text
*.mask text
*.lighting text
*.preset text
*.renderTexture text
*.terrainlayer text
*.wlt text

# Keep common binary assets out of text normalization
*.png -text
*.jpg -text
*.jpeg -text
*.tif -text
*.tiff -text
*.exr -text
*.psd -text
*.pdf -text
*.ttf -text
*.mp4 -text

# Large 3D assets in this repo
*.fbx filter=lfs diff=lfs merge=lfs -text
